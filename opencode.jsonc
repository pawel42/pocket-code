{
  "$schema": "https://opencode.ai/config.schema.json",
  "default_agent": "manager",
  "instructions": [
    ".opencode/instructions/project-overview.md",
    ".opencode/instructions/code-best-practices.md"
  ],
  "mcp": {
    "expo": {
      "enabled": true
    }
  },
  "agent": {
    "manager": {
      "permission": {
        "task": {
          "*": "deny",
          "planner": "allow",
          "implementer": "allow",
          "reviewer": "allow",
          "tester": "allow"
        }
      }
    }
  }
}
